# Production backend runtime example
# 이 파일은 Windows Service/NSSM/WinSW 등으로 backend 를 직접 실행할 때 참고하는 예제다.
# Docker Compose 로 운영할 때는 루트 `.env` 를 `.env.docker.example` 기준으로 작성하고,
# 여기서는 같은 의미의 host runtime 값만 참고한다.
# direct runtime 에서는 APP_DB_URL 을 직접 넣고, Docker Compose 에서는 APP_DB_URL_DOCKER 를 루트 `.env` 에 넣는다.
# 실제 비밀번호, 실제 운영 계정명, 실제 운영 서버 주소는 저장소에 넣지 않는다.

# 운영 인프라 담당자가 제공한다.
# 기준: 실제 backend 가 바인딩될 포트와 health 확인 포트.
# 기록 위치: 서비스 환경변수 또는 운영 서버 작업본.
APP_SERVER_PORT=8080

# 서비스 운영 책임자 또는 보안 정책 담당자가 제공한다.
# 기준: 세션/쿠키 기반 인증 유지 시간 정책.
# 기록 위치: 서비스 환경변수 또는 운영 서버 작업본.
APP_SESSION_TIMEOUT=120m

# 인프라 담당자가 제공한다.
# 기준: reverse proxy 뒤 운영 여부. proxy 가 없으면 기본값 none 을 유지한다.
# 기록 위치: 서비스 환경변수 또는 운영 서버 작업본.
APP_FORWARD_HEADERS_STRATEGY=none

# DB 관리자가 제공한다.
# 기준: 실제 운영 DB 계열과 일치해야 하며 `.env.docker.example` 의 APP_DB_DRIVER 와 같은 의미다.
# 기록 위치: 서비스 환경변수 또는 운영 서버 작업본.
APP_DB_DRIVER=org.mariadb.jdbc.Driver

# DB 관리자가 제공한다.
# 기준: host runtime 에서 backend 가 직접 사용할 JDBC URL.
# Docker Compose 루트 `.env` 의 APP_DB_URL_DOCKER 와 host/port/name/querystring 기준을 맞춘다.
# application-prod.yml 은 direct runtime 에서 이 APP_DB_URL 값을 그대로 읽는다.
# 기록 위치: 서비스 환경변수 또는 운영 서버 작업본.
APP_DB_URL=jdbc:mariadb://DB_HOST_PLACEHOLDER:3306/DB_NAME_PLACEHOLDER?useUnicode=true&characterEncoding=utf8

# DB 관리자가 제공한다.
# 기준: 운영 앱 전용 DB 계정. `.env.docker.example` 의 APP_DB_USERNAME 과 같은 의미다.
# 기록 위치: 서비스 환경변수 또는 비밀 저장소 참조 문서.
APP_DB_USERNAME=DB_USERNAME_PLACEHOLDER

# DB 관리자 또는 비밀 관리 담당자가 제공한다.
# 기준: 운영 앱 전용 DB 비밀번호. 실제 값은 비밀 저장소에만 두고 저장소에는 placeholder 를 유지한다.
# 기록 위치: 서비스 환경변수 또는 비밀 저장소.
APP_DB_PASSWORD=DB_PASSWORD_PLACEHOLDER

# 서비스 운영 책임자가 제공한다.
# 기준: 운영 화면에 노출할 시스템 이름. 기본값을 유지해도 되면 그대로 둔다.
# 기록 위치: 서비스 환경변수 또는 운영 서버 작업본.
APP_ORGANIZATION_NAME=다시서기 정신건강 평가관리 시스템

# 인프라 담당자가 제공한다.
# 기준: backend 파일 로그를 남길 실제 writable 경로.
# Docker Compose 운영이면 루트 `.env` 의 BACKEND_LOGS_HOST_PATH 와 같은 의미다.
# 기록 위치: 서비스 환경변수 또는 운영 서버 작업본.
APP_LOG_FILE_PATH=D:\apps\mental-health\logs\application

# 애플리케이션 운영 담당자가 제공한다.
# 기준: `classpath:scales` 유지 또는 외부 filesystem 경로 사용 여부.
# 실제 운영 척도 JSON 배치 위치와 일치해야 한다.
# 기록 위치: 서비스 환경변수 또는 운영 서버 작업본.
APP_SCALE_RESOURCE_PATH=D:\apps\mental-health\app\backend\scales

# 인프라 담당자가 제공한다.
# 기준: CSV export 임시 파일을 생성할 writable 경로.
# 기록 위치: 서비스 환경변수 또는 운영 서버 작업본.
APP_EXPORT_TEMP_PATH=D:\apps\mental-health\temp\exports

# 인프라 담당자가 제공한다.
# 기준: 백업 파일 루트 경로. `.env.docker.example` 의 BACKEND_BACKUPS_HOST_PATH 와 같은 의미의 루트 경로다.
# 기록 위치: 서비스 환경변수 또는 운영 서버 작업본.
APP_BACKUP_ROOT_PATH=D:\apps\mental-health\backups

# DB 관리자 또는 실제 운영 반영 담당자가 제공한다.
# 기준: `mysql`/`mariadb-dump`/`mysqldump` 또는 동등한 DB 적용 수단이 실제로 존재하는지 확인한 뒤 넣는다.
# Docker Compose 운영이면 루트 `.env` 의 APP_DB_DUMP_COMMAND 와 같은 의미다.
# `/api/v1/admin/backups/run` 과 `scripts/admin-smoke-check.bat` 도 이 값 또는 운영 대체 수단에 영향을 받는다.
# 기록 위치: 서비스 환경변수 또는 운영 서버 작업본.
APP_DB_DUMP_COMMAND=C:\Program Files\MariaDB 11.4\bin\mariadb-dump.exe

# 인프라 담당자가 제공한다.
# 기준: 신뢰 가능한 내부 reverse proxy 뒤면 true, 아니면 false.
# APP_FORWARD_HEADERS_STRATEGY 와 같이 결정해야 한다.
# 기록 위치: 서비스 환경변수 또는 운영 서버 작업본.
APP_TRUST_PROXY_HEADERS=false

