# Production Environment Variables
# Copy this file to .env.prod and fill in actual values

# Database Configuration
PROD_DB_NAME=mental_health
PROD_DB_USERNAME=mental_user
PROD_DB_PASSWORD=change_me_with_secure_password
PROD_DB_ROOT_PASSWORD=change_me_with_secure_root_password

# Application Configuration
APP_DB_DRIVER=org.mariadb.jdbc.Driver
APP_SESSION_TIMEOUT=120m
APP_FORWARD_HEADERS_STRATEGY=none
APP_TRUST_PROXY_HEADERS=false
