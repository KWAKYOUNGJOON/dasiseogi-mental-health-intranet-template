# 운영 환경 예시 템플릿
# 배포 절차에 맞게 `.env.prod` 로 복사해 사용한다.
# 로컬 Windows 기본 경로는 `.env.docker.example` + 루트 `docker compose up -d --build` 이다.
# 이 파일은 `docker-compose.prod.yml` 또는 운영용 외부 DB 경로를 위한 템플릿이다.
# 기동 전 점검 예:
#   docker compose --env-file .env.prod config
#   docker compose -f docker-compose.prod.yml --env-file .env.prod config
# cspell:words HEALTHCHECK

# 운영용 외부 DB 또는 운영 profile 경로
APP_DB_URL_DOCKER=jdbc:mariadb://host.docker.internal:3306/DB_NAME_PLACEHOLDER?useUnicode=true&characterEncoding=utf8
APP_DB_USERNAME=DB_USERNAME_PLACEHOLDER
APP_DB_PASSWORD=DB_PASSWORD_PLACEHOLDER
APP_DB_DRIVER=org.mariadb.jdbc.Driver
APP_SERVER_PORT=8080
APP_FRONTEND_PORT=4173
APP_BACKEND_UPSTREAM_HOST=backend
APP_HEALTHCHECK_PATH=/api/v1/health
APP_SESSION_TIMEOUT=120m
APP_FORWARD_HEADERS_STRATEGY=none
APP_TRUST_PROXY_HEADERS=false
APP_DB_DUMP_COMMAND=
BACKEND_LOGS_HOST_PATH=./logs
BACKEND_TMP_HOST_PATH=./tmp
BACKEND_BACKUPS_HOST_PATH=./local-backups

# `docker-compose.prod.yml` 로 내장 MariaDB 를 함께 띄울 때만 사용
PROD_DB_NAME=PROD_DB_NAME_PLACEHOLDER
PROD_DB_USERNAME=PROD_DB_USERNAME_PLACEHOLDER
PROD_DB_PASSWORD=PROD_DB_PASSWORD_PLACEHOLDER
PROD_DB_ROOT_PASSWORD=PROD_DB_ROOT_PASSWORD_PLACEHOLDER
