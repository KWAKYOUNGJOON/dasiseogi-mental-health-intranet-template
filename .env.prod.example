# Production Environment Variables
# Copy this file to .env.prod and fill in actual values
# cspell:words HEALTHCHECK

# Database Configuration
PROD_DB_NAME=PROD_DB_NAME_PLACEHOLDER
PROD_DB_USERNAME=PROD_DB_USERNAME_PLACEHOLDER
PROD_DB_PASSWORD=PROD_DB_PASSWORD_PLACEHOLDER
PROD_DB_ROOT_PASSWORD=PROD_DB_ROOT_PASSWORD_PLACEHOLDER

# Application Configuration
APP_SERVER_PORT=8080
APP_FRONTEND_PORT=4173
APP_BACKEND_UPSTREAM_HOST=backend
APP_HEALTHCHECK_PATH=/api/v1/health
APP_DB_DRIVER=org.mariadb.jdbc.Driver
APP_SESSION_TIMEOUT=120m
APP_FORWARD_HEADERS_STRATEGY=none
APP_TRUST_PROXY_HEADERS=false
