# Deprecated compatibility sample.
# 기본 로컬 실행 경로는 이제 `.env.docker.example` -> `.env` 복사 후
# 저장소 루트에서 `docker compose up -d --build` 를 실행하는 방식이다.
# 아래 값은 루트 `.env` 로 옮겨 적어 커스터마이즈할 때만 참고한다.

LOCAL_DB_NAME=mental_health_local
LOCAL_DB_USERNAME=mental_user
LOCAL_DB_PASSWORD=mental_pass
LOCAL_DB_ROOT_PASSWORD=mental_root_pass
