# 선택형 local DB override 용 예시값이다.
# 필요할 때 아래 값을 루트 `.env` 에 추가하거나 현재 셸 환경변수로 주입한다.
# 기본 `docker compose up -d` 외부 DB 경로는 그대로 유지하고,
# 아래 값은 `-f docker-compose.local-db.yml` 를 함께 쓸 때만 참고한다.
# local DB override 는 backend 를 명시적 `local` profile 로 기동한다.
# 이 파일의 값은 운영이 아니라 local/dev 전용이다.

LOCAL_DB_NAME=mental_health_local
LOCAL_DB_USERNAME=mental_user
LOCAL_DB_PASSWORD=mental_pass
LOCAL_DB_ROOT_PASSWORD=mental_root_pass
