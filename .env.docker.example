# Docker 실행 전 이 파일을 복사해 루트 `.env` 로 사용한다.
# 실제 값은 docs/20-production-input-sheet.md 복사본 또는 내부 운영 문서를 기준으로만 채운다.
# 실제 DB 주소, 계정, 비밀번호는 직접 입력해야 하며 placeholder 값은 커밋하지 않는다.
# `APP_DB_URL_DOCKER` 는 Docker 전용 입력값이고, backend/docker-entrypoint.sh 가 이를 `APP_DB_URL` 로 넘겨 application-prod.yml 이 읽는다.
# `.env` 가 없거나 `APP_DB_URL_DOCKER` 가 비어 있으면 운영 DB 대신 다른 경로로 기동될 수 있으므로,
# `docker compose up -d` 전에 반드시 `docker compose config` 로 값이 실제로 채워졌는지 확인한다.

# 필수값: Docker backend 가 외부 MariaDB 로 기동하기 위한 값
APP_DB_URL_DOCKER=jdbc:mariadb://host.docker.internal:3306/DB_NAME_PLACEHOLDER?useUnicode=true&characterEncoding=utf8
APP_DB_USERNAME=DB_USERNAME_PLACEHOLDER
APP_DB_PASSWORD=DB_PASSWORD_PLACEHOLDER

# 선택값: 운영 정책 또는 DB 종류에 따라 조정한다.
APP_DB_DRIVER=org.mariadb.jdbc.Driver
APP_SESSION_TIMEOUT=120m
APP_FORWARD_HEADERS_STRATEGY=none
APP_TRUST_PROXY_HEADERS=false

# 선택값: 호스트에서 앱이나 배치 스크립트를 직접 실행할 때 참고하는 JDBC URL 예시다.
# direct runtime 경로를 쓰지 않으면 placeholder 그대로 두고, Docker 운영에서는 APP_DB_URL_DOCKER 를 기준으로 확인한다.
APP_DB_URL=jdbc:mariadb://DB_HOST_PLACEHOLDER:3306/DB_NAME_PLACEHOLDER?useUnicode=true&characterEncoding=utf8

# 선택값: 현재 공식 backend Docker 이미지에는 mariadb-dump / mysqldump 가 기본 포함되지 않는다.
# 컨테이너 내부 DB_DUMP 가 필요하면 dump 바이너리가 포함된 파생 이미지를 쓰고 절대 경로를 넣는다.
# `/api/v1/admin/backups/run` 또는 `scripts/admin-smoke-check.bat` 를 운영에서 쓸 계획이면 값 또는 대체 수단을 docs/20 복사본에 먼저 적는다.
APP_DB_DUMP_COMMAND=

# 호스트 경로: 로그, 임시 export 파일, 백업 파일이 이 경로 아래에 남는다.
# docker-compose.yml 은 이 값을 각각 /data/logs, /data/tmp, /data/backups 로 바인드한다.
BACKEND_LOGS_HOST_PATH=./logs
BACKEND_TMP_HOST_PATH=./tmp
BACKEND_BACKUPS_HOST_PATH=./local-backups

