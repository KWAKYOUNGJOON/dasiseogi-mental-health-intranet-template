# 이 파일을 저장소 루트의 `.env` 로 복사해 `docker-compose.yml` 과 같은 위치에 둔다.
# 예:
#   cp .env.docker.example .env
# `docker compose config` 실행 전에 필수 DB 값을 반드시 채운다.
# 필수값이 비어 있으면 `docker compose config` 또는 `docker compose up -d --build`
# 단계에서 `... is required` 로 멈춘다.
# DB 값이 `PLACEHOLDER` 상태로 남아 있으면 backend entrypoint 가 fail-fast 로 중단된다.
# backend 직접 실행 예시는 `docs/examples/production-runtime.env.example` 를 본다.

# 필수값: `docker-compose.yml` 기준 backend 가 외부 MariaDB 로 기동할 때 필요하다.
# backend 컨테이너가 접속할 외부 MariaDB JDBC URL
APP_DB_URL_DOCKER=jdbc:mariadb://host.docker.internal:3306/DB_NAME_PLACEHOLDER?useUnicode=true&characterEncoding=utf8
# backend 가 사용할 MariaDB 애플리케이션 계정
APP_DB_USERNAME=DB_USERNAME_PLACEHOLDER
# 실제 DB 비밀번호로 바꿔 넣는다. 실제 값은 커밋하지 않는다.
APP_DB_PASSWORD=DB_PASSWORD_PLACEHOLDER
# JDBC 드라이버 클래스. DB 엔진이 바뀌지 않으면 MariaDB 기본값을 유지한다.
APP_DB_DRIVER=org.mariadb.jdbc.Driver

# 선택값: 비워 두면 `docker-compose.yml` 의 현재 기본값이 적용된다.
# backend 컨테이너 포트이자 frontend 가 backend 에 붙을 때 기준이 되는 포트
APP_SERVER_PORT=8080
# 운영자가 접속할 frontend 포트
APP_FRONTEND_PORT=4173
# compose 네트워크 안에서 frontend 가 backend 를 찾을 때 쓰는 호스트명
APP_BACKEND_UPSTREAM_HOST=backend
# backend / frontend health 확인 경로. 기본 healthcheck 경로는 `/api/v1/health`
APP_HEALTHCHECK_PATH=/api/v1/health
# 로그인 세션 유지 시간
APP_SESSION_TIMEOUT=120m
# reverse proxy 헤더 처리 전략. 신뢰 가능한 프록시 앞단이 아니면 `none` 유지
APP_FORWARD_HEADERS_STRATEGY=none
# 신뢰 가능한 reverse proxy 를 실제로 쓸 때만 `true`
APP_TRUST_PROXY_HEADERS=false
# backend 컨테이너 안에서 쓸 DB dump 바이너리 경로. 커스텀 이미지가 없으면 비워 둔다.
APP_DB_DUMP_COMMAND=

# bind mount 호스트 경로. `docker compose up -d --build` 전에 존재/쓰기 가능 여부를 확인한다.
BACKEND_LOGS_HOST_PATH=./logs
BACKEND_TMP_HOST_PATH=./tmp
BACKEND_BACKUPS_HOST_PATH=./local-backups
