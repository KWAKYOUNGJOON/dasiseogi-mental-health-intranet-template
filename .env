# 이 파일을 저장소 루트의 `.env` 로 복사해 루트 `docker-compose.yml` 과 같은 위치에 둔다.
# 기본 로컬 실행 경로는 저장소 루트에서 아래 한 줄이다.
#   docker compose up -d --build
# Docker Desktop 에서는 `dasiseogi-mental-health-intranet-template` 프로젝트 아래에
# `db`, `backend`, `frontend` 컨테이너가 보여야 정상이다.
# Windows PowerShell 예:
#   Copy-Item .env.docker.example .env

# 기본 멀티 컨테이너 로컬 스택은 `local` profile 로 실행된다.
SPRING_PROFILES_ACTIVE=local

# backend / frontend 기본 포트
APP_SERVER_PORT=8080
APP_FRONTEND_PORT=4173
APP_BACKEND_UPSTREAM_HOST=backend
APP_HEALTHCHECK_PATH=/api/v1/health

# backend 기본 동작
APP_SESSION_TIMEOUT=120m
APP_FORWARD_HEADERS_STRATEGY=none
APP_TRUST_PROXY_HEADERS=false
APP_DB_DRIVER=org.mariadb.jdbc.Driver
APP_DB_DUMP_COMMAND=

# compose 내부 MariaDB 기본값
LOCAL_DB_NAME=mental_health_local
LOCAL_DB_USERNAME=mental_user
LOCAL_DB_PASSWORD=mental_pass
LOCAL_DB_ROOT_PASSWORD=mental_root_pass

# bind mount 호스트 경로
BACKEND_LOGS_HOST_PATH=./logs
BACKEND_TMP_HOST_PATH=./tmp
BACKEND_BACKUPS_HOST_PATH=./local-backups

# single-container 는 더 이상 기본 경로가 아니다.
# `docker-compose.single-container.yml` 은 필요할 때만 선택적으로 사용한다.
